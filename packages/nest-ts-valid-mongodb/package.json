{
  "name": "@ioni/nest-ts-valid-mongodb",
  "version": "0.3.0",
  "description": "High-performance MongoDB Native Driver wrapper for NestJS with Zod schema validation. Lightweight, type-safe, and robust",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/*.cjs",
    "dist/*.mjs",
    "dist/*.d.cts",
    "dist/*.d.mts",
    "dist/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "commonjs",
  "sideEffects": false,
  "keywords": [
    "nestjs",
    "mongodb",
    "zod",
    "validation",
    "native-driver",
    "typescript",
    "schema",
    "odm",
    "orm",
    "database",
    "nosql"
  ],
  "author": "Johnny J. Huirilef",
  "license": "MIT",
  "homepage": "https://github.com/johnnyhuirilef/toolkit/tree/main/packages/nest-ts-valid-mongodb#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnnyhuirilef/toolkit.git",
    "directory": "packages/nest-ts-valid-mongodb"
  },
  "bugs": {
    "url": "https://github.com/johnnyhuirilef/toolkit/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "mongodb": "^5.0.0 || ^6.0.0",
    "ts-valid-mongodb": "^1.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@nx/vite": "^22.0.0",
    "jsonc-eslint-parser": "^2.0.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {}
}
